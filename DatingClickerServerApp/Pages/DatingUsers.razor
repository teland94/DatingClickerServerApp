@page "/dating-users"
@using DatingClickerServerApp.Common.Extensions
@using DatingClickerServerApp.Common.Model
@using DatingClickerServerApp.Common.Persistence
@using DatingClickerServerApp.Components
@using DatingClickerServerApp.Modals
@using Microsoft.EntityFrameworkCore

<PageTitle>Dating Clicker Users</PageTitle>

<div class="mb-2 d-flex align-items-center">
    <div class="form-check me-3">
        <input class="form-check-input" type="checkbox" @bind="_onlyVerified" @bind:after="FilterUsers" />
        <label class="form-check-label" for="onlyVerified">
            Только верифицированные
        </label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" @bind="_onlyToday" @bind:after="FilterUsers" />
        <label class="form-check-label" for="onlyToday">
            Только сегодняшние
        </label>
    </div>
</div>

<div class="input-group mb-3">
    <input type="text" class="form-control" placeholder="Поиск по ID, описанию или интересам" aria-label="Поиск по ID, описанию или интересам" aria-describedby="button-search"
        @bind-value="_searchText" @bind-value:event="oninput" @onkeypress="OnKeyPress">
    <div class="input-group-append">
        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch" disabled="@string.IsNullOrEmpty(_searchText)">
            <span class="oi oi-x" title="clear" aria-hidden="true"></span>
        </button>
    </div>
    <div class="input-group-append">
        <button class="btn btn-outline-secondary" type="button" id="button-search" @onclick="OnSearch">
            <span class="oi oi-magnifying-glass" title="search" aria-hidden="true"></span>
        </button>
    </div>
</div>

<p>Количество: @_totalUsers</p>

<div class="table-responsive">
    <table class="table table-bordered mb-3">
        <thead class="thead-dark">
            <tr>
                <th>ID</th>
                <th>Фото</th>
                <th>✔</th>
                <th>Возраст</th>
                <th>👶</th>
                <th>Рост</th>
                <th>О себе</th>
                <th>Интересы</th>
                <th>Локация</th>
                <th>👀</th>
                <th>Дата</th>
            </tr>
        </thead>
        <tbody>
            @if (_users != null)
            {
                @foreach (var user in _users)
                {
                    var actionGroups = user.Actions
                        .GroupBy(a => a.DatingUserId)
                        .Select(g => new
                        {
                            DatingUserId = g.Key,
                            ActionType = g.Last().ActionType,
                            Count = g.Count(),
                            LatestDate = g.Max(a => a.CreatedDate)
                        })
                        .ToList();

                    var lastAction = actionGroups.OrderByDescending(ag => ag.LatestDate).FirstOrDefault();

                    var rowClass = lastAction.ActionType switch
                    {
                        DatingUserActionType.SuperLike => "table-success",
                        DatingUserActionType.Dislike => "table-danger",
                        DatingUserActionType.None => "table-warning",
                        _ => ""
                    };

                    <tr class="@rowClass">
                        <td>
                            <a href="javascript:void(0)" @onclick="() => ShowUserModal(user)">
                                @user.ExternalId
                            </a>
                        </td>
                        <td><a target="_blank" href="@ExtractShareUrlFromJsonData(user.JsonData)"><img src="@user.PreviewUrl" alt="Превью" class="img-thumbnail" style="max-width: 150px; max-height: 150px; object-fit: contain" /></a></td>
                        <td>@(user.IsVerified ? "✔" : "")</td>
                        <td>@user.Age</td>
                        <td>@(user.HasChildren.HasValue && user.HasChildren.Value ? "👶" : "")</td>
                        <td>@user.Height</td>
                        <td>@user.About</td>
                        <td>@string.Join(", ", user.Interests)</td>
                        <td class="text-nowrap"><span class="small-emoji">📍</span> @(user.CityName ?? ExtractDistanceFromJsonData(user.JsonData))</td>
                        <td class="text-nowrap">
                            @(lastAction.ActionType switch
                            {
                                DatingUserActionType.None => "➖",
                                DatingUserActionType.Like => "❤️",
                                DatingUserActionType.Dislike => "❌",
                                DatingUserActionType.SuperLike => "🔥",
                                _ => ""
                            })
                            @if (actionGroups.Any(ag => ag.Count > 1))
                            {
                                <span>*</span>
                            }
                        </td>
                        <td>@actionGroups.Max(ag => ag.LatestDate.ConvertToLocalTime()).ToString("dd.MM.yyyy HH:mm")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <Pagination CurrentPage="@_currentPage" TotalPages="@_totalPages" OnPageChanged="GoToPage" />

    <DatingUserModal User="_selectedUser" />
</div>

<style>
    .small-emoji {
        font-size: 0.6em;
    }
</style>

<script>
    function scrollToTop() {
        window.scrollTo(0, 0);
    }
</script>
